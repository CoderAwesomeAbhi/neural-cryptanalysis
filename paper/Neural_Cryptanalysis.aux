\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Gradual transition in neural predictability. MLP accuracy declines from $100\%$ at $T/L_{\mathrm  {in}}=4.8$ through $85\%$ at 35.3, $66\%$ at 46.8, $36\%$ at 76.0, and $18\%$ at 118.8, reaching near-random performance above ratio $\sim $150. The transition is gradual over $T/L_{\mathrm  {in}} \approx 35$--150, not a sharp discontinuity. Ablation studies confirm stability across training sizes (1800--7200), model capacities (64--256 hidden), and context lengths (6--24), with $L_{\mathrm  {in}}$ the primary bottleneck.}}{25}{figure.caption.13}\protected@file@percent }
\newlabel{fig:phase_transition}{{4}{25}{Gradual transition in neural predictability. MLP accuracy declines from $100\%$ at $T/L_{\mathrm {in}}=4.8$ through $85\%$ at 35.3, $66\%$ at 46.8, $36\%$ at 76.0, and $18\%$ at 118.8, reaching near-random performance above ratio $\sim $150. The transition is gradual over $T/L_{\mathrm {in}} \approx 35$--150, not a sharp discontinuity. Ablation studies confirm stability across training sizes (1800--7200), model capacities (64--256 hidden), and context lengths (6--24), with $L_{\mathrm {in}}$ the primary bottleneck}{figure.caption.13}{}}
