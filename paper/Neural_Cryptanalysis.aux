\newlabel{tab:neural}{{7}{18}{MLP-(256,128) top-1 validation accuracy at 50 epochs, mean $\pm $ std over 5 seeds. The threshold between learnable and unlearnable lies in $T/L_{\mathrm {in}} \in (21, 181)$}{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Phase transition in neural predictability. MLP accuracy collapses from $100\%$ to $<17\%$ as $T/L_{\mathrm  {in}}$ crosses the critical threshold $\approx 21$. The sharp transition demonstrates an information-theoretic barrier: when period exceeds training data by factor $>25$, most transitions appear $\leq 1$ times, making generalization impossible.}}{18}{figure.caption.11}\protected@file@percent }
\newlabel{fig:phase_transition}{{4}{18}{Phase transition in neural predictability. MLP accuracy collapses from $100\%$ to $<17\%$ as $T/L_{\mathrm {in}}$ crosses the critical threshold $\approx 21$. The sharp transition demonstrates an information-theoretic barrier: when period exceeds training data by factor $>25$, most transitions appear $\leq 1$ times, making generalization impossible}{figure.caption.11}{}}
